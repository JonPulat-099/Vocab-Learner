# apps/server/.env.example
# copy to .env — never commit the real one

# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Koyeb injects PORT in prod; keep 3000 locally

# ── Telegram ────────────────────────────────────────────
BOT_TOKEN=123456789:AA...                # @BotFather
BOT_MODE=polling                         # polling (dev) | webhook (prod)
WEBHOOK_URL=https://<app>.koyeb.app      # prod only, base URL without path
WEBHOOK_SECRET=change-me-random-64-chars # path segment + X-Telegram-Bot-Api-Secret-Token
OWNER_TG_ID=123456789                    # your tg id — single-user guard, bot ignores everyone else

# ── Dictionary sources ──────────────────────────────────
MW_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # dictionaryapi.com (Collegiate)
CAMBRIDGE_BASE_URL=https://dictionary.cambridge.org/dictionary/english-russian
SOURCE_TIMEOUT_MS=5000                   # per-source fetch timeout
YOUGLISH_API_KEY=                        # optional, Tier 2 — leave empty for deep links

# ── Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...                   # aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=15000

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # service role — server only, NEVER ship to web
WORD_CACHE_TTL_DAYS=0                    # 0 = cache forever (recommended)

# ── Web auth ────────────────────────────────────────────
JWT_SECRET=change-me-random-64-chars
JWT_EXPIRES_IN=30d
WEB_ORIGIN=http://localhost:5173         # prod: https://<project>.pages.dev — used for CORS + Login Widget

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info                           # pino: debug | info | warn | error
