# apps/server/.env.example
# copy to .env — never commit the real one

# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Railway injects PORT in prod; keep 3000 locally

# ── Telegram ────────────────────────────────────────────
BOT_TOKEN=123456789:AA...                # @BotFather
BOT_MODE=polling                         # polling (dev) | webhook (prod)
WEBHOOK_URL=                             # prod only, e.g. https://myapp.up.railway.app (base URL without path)
WEBHOOK_SECRET=change-me-random-64-chars # path segment + X-Telegram-Bot-Api-Secret-Token
OWNER_TG_ID=123456789                    # your tg id — single-user guard; blank = bot open to everyone (also disables /api/auth/dev)

# ── Dictionary sources ──────────────────────────────────
MW_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # dictionaryapi.com (Collegiate)
CAMBRIDGE_BASE_URL=https://dictionary.cambridge.org/dictionary/english-russian
SOURCE_TIMEOUT_MS=5000                   # per-source fetch timeout
YOUGLISH_API_KEY=                        # optional, Tier 2 — leave empty for deep links

# ── AI providers ────────────────────────────────────────
# All optional, but at least one must be configured. The active one is chosen
# at runtime by the owner via the hidden /model bot command.

# Gemini — aistudio.google.com
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=15000

# DeepSeek — platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=15000

# GLM (Zhipu / Z.ai) — z.ai / bigmodel.cn
GLM_API_KEY=
GLM_MODEL=glm-5
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_TIMEOUT_MS=15000

# Sakana Fugu — console.sakana.ai
SAKANA_API_KEY=
SAKANA_MODEL=fugu
SAKANA_BASE_URL=https://api.sakana.ai/v1
SAKANA_TIMEOUT_MS=15000

# Kimi (Moonshot AI) — platform.moonshot.ai
KIMI_API_KEY=
KIMI_MODEL=kimi-k3
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_TIMEOUT_MS=15000

# GitHub Copilot via self-hosted OpenAI-compatible proxy (e.g. copilot-api).
# Setting the base URL enables the provider; API key is a placeholder unless
# your proxy checks one.
COPILOT_BASE_URL=
COPILOT_API_KEY=copilot-proxy
COPILOT_MODEL=gpt-4.1
COPILOT_TIMEOUT_MS=15000

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # service role — server only, NEVER ship to web
WORD_CACHE_TTL_DAYS=0                    # 0 = cache forever (recommended)

# ── Web auth ────────────────────────────────────────────
JWT_SECRET=change-me-random-64-chars
JWT_EXPIRES_IN=30d
WEB_ORIGIN=http://localhost:5173         # prod: https://<project>.pages.dev — used for CORS + Login Widget

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info                           # pino: debug | info | warn | error
