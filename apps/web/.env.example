# apps/web/.env.example
# Vite exposes only VITE_* vars to the client — nothing secret here.
# In prod they are GitHub repo variables passed as Docker build args
# (baked into the bundle when CI builds apps/web/Dockerfile).

VITE_API_URL=http://localhost:3000       # prod: https://<service>.up.railway.app
VITE_TG_BOT_USERNAME=your_bot_username   # for the Telegram Login Widget (data-telegram-login)
VITE_YOUGLISH_LANG=english               # widget default: english | english/us | english/uk
